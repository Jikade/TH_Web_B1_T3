@model _2380600659_HieuNguyen.Models.Product

@{
    ViewData["Title"] = "Product Details";
}

<h2 class="mb-4">Product Details</h2>

<div class="card shadow p-4">

    <div class="row">

        <div class="col-md-4">

            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl"
                     class="img-fluid rounded"
                     style="max-height:300px;object-fit:cover;">
            }

        </div>

        <div class="col-md-8">

            <h3>@Model.Name</h3>

            <h4 class="text-success">$@Model.Price</h4>

            <p class="mt-3">@Model.Description</p>

            <p>
                <b>Category:</b> @Model.Category?.Name
            </p>

            <form method="post" asp-controller="ShoppingCart" asp-action="AddToCart">
                <input type="hidden" name="productId" value="@Model.Id" />
                <div class="input-group mb-3" style="width: 150px;">
                    <span class="input-group-text">SL:</span>
                    <input type="number" name="count" class="form-control" value="1" min="1" />
                </div>
                <button type="submit" class="btn btn-primary shadow-0"> <i class="me-1 fa fa-shopping-basket"></i> Thêm vào giỏ </button>
                <a asp-action="Index" class="btn btn-secondary mt-2">Quay lại danh sách</a>
            </form>

        </div>

    </div>

</div>