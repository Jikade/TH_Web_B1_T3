@model IEnumerable<_2380600659_HieuNguyen.Models.ShoppingCart>

@{
    ViewData["Title"] = "Giỏ hàng của bạn";
}

<div class="container mt-4">
    <h2 class="mb-4">🛒 Giỏ hàng của bạn</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center">
            Giỏ hàng của bạn đang trống! <a asp-controller="Product" asp-action="Index">Quay lại mua sắm</a>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-center">Đơn giá</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle fw-bold">@item.Product.Name</td>
                                <td class="align-middle text-center">$@item.Product.Price</td>
                                <td class="align-middle text-center">@item.Count</td>
                                <td class="align-middle text-end text-success fw-bold">$@(item.Product.Price * item.Count)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center bg-light p-3 border rounded shadow-sm">
            <form asp-action="ClearCart" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xoá toàn bộ sản phẩm trong giỏ hàng?');">
                <button type="submit" class="btn btn-outline-danger" style="border-radius: 20px;">
                    🗑 Xoá toàn bộ
                </button>
            </form>

            <div class="text-end d-flex align-items-center">
                <h4 class="mb-0 me-4">Tổng cộng: <span class="text-danger fw-bold">$@Model.Sum(i => i.Product.Price * i.Count)</span></h4>
                <a asp-action="Summary" class="btn btn-success px-4 py-2 fw-bold" style="border-radius: 20px;">
                    Tiến hành thanh toán ➡
                </a>
            </div>
        </div>
    }
</div>