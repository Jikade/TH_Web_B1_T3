@model IEnumerable<_2380600659_HieuNguyen.Models.ShoppingCart>
<div class="container mt-4">
    <h2>Giỏ hàng của bạn</h2>
    <table class="table">
        <thead><tr><th>Sản phẩm</th><th>Giá</th><th>Số lượng</th><th>Tổng</th></tr></thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Product.Name</td>
                    <td>$@item.Product.Price</td>
                    <td>@item.Count</td>
                    <td>$@(item.Product.Price * item.Count)</td>
                </tr>
            }
        </tbody>
    </table>
    <div class="text-end">
        <h4>Tổng cộng: $@Model.Sum(i => i.Product.Price * i.Count)</h4>
        <a asp-action="Summary" class="btn btn-success mt-2">Tiến hành thanh toán</a>
    </div>
</div>