@model IEnumerable<_2380600659_HieuNguyen.Models.OrderHeader>

@{
    ViewData["Title"] = "Lịch sử đơn hàng";
}

<div class="container mt-4">
    <h2 class="mb-4">📦 Lịch sử mua hàng của bạn</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Bạn chưa có đơn hàng nào. <a asp-controller="Product" asp-action="Index" class="alert-link">Tiếp tục mua sắm</a>
        </div>
    }
    else
    {
        <table class="table table-bordered table-hover shadow-sm bg-white">
            <thead class="table-dark">
                <tr>
                    <th>Mã ĐH</th>
                    <th>Ngày Đặt</th>
                    <th>Tổng Tiền</th>
                    <th>Trạng Thái</th>
                    <th>Chi tiết</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="align-middle fw-bold">#@item.Id</td>
                        <td class="align-middle">@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="align-middle"><span class="text-success fw-bold">$@item.OrderTotal</span></td>
                        <td class="align-middle">
                            @if (item.OrderStatus == _2380600659_HieuNguyen.Models.SD.StatusPending)
                            {
                                <span class="badge bg-warning text-dark">@item.OrderStatus</span>
                            }
                            else if (item.OrderStatus == _2380600659_HieuNguyen.Models.SD.StatusApproved)
                            {
                                <span class="badge bg-primary">@item.OrderStatus</span>
                            }
                            else if (item.OrderStatus == _2380600659_HieuNguyen.Models.SD.StatusShipped)
                            {
                                <span class="badge bg-success">@item.OrderStatus</span>
                            }
                            else if (item.OrderStatus == _2380600659_HieuNguyen.Models.SD.StatusCancelled)
                            {
                                <span class="badge bg-danger">@item.OrderStatus</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@item.OrderStatus</span>
                            }
                        </td>
                        <td class="align-middle text-center">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm">Xem chi tiết</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>