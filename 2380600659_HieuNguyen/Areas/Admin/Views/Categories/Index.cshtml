@model IEnumerable<_2380600659_HieuNguyen.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">📁 Quản lý Danh mục</h2>
    <a asp-action="Add" class="btn btn-primary px-4 shadow-sm">
        <i class="me-1 fa fa-plus-circle"></i> + Thêm Danh mục
    </a>
</div>

<div class="card admin-card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light border-bottom">
                <tr>
                    <th class="ps-4">ID</th>
                    <th>Tên Danh mục</th>
                    <th width="200" class="text-center">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 align-middle fw-bold">@item.Id</td>
                        <td class="align-middle">@item.Name</td>
                        <td class="align-middle text-center">
                            <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-warning btn-sm me-1 text-dark">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>