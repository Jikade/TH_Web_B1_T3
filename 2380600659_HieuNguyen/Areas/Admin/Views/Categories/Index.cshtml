@model IEnumerable<_2380600659_HieuNguyen.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<h2 class="mb-4">Category Management</h2>

<a asp-action="Add" class="btn btn-primary mb-3">+ Add New Category</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Category Name</th>
            <th width="250">Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>

                <td>
                    <a asp-action="Display" asp-route-id="@item.Id" class="btn btn-info btn-sm">
                        View
                    </a>

                    <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                        Edit
                    </a>

                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>