<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* CSS tùy chỉnh cho Admin */
        body {
            background-color: #f4f6f9;
        }

        .admin-card {
            border-radius: 12px;
            border: none;
            overflow: hidden;
        }

        .form-control, .form-select {
            border-radius: 8px;
        }

        .btn {
            border-radius: 8px;
            font-weight: 500;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark shadow-sm mb-4 py-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold tracking-wide" asp-area="Admin" asp-controller="Product" asp-action="Index">
                    ⚙️ E-Shop <span class="text-warning">Admin</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-4 gap-2">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="Admin" asp-controller="Product" asp-action="Index">📦 Sản phẩm</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="Admin" asp-controller="Categories" asp-action="Index">📁 Danh mục</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="Admin" asp-controller="Order" asp-action="Index">📋 Đơn hàng</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav align-items-center gap-3">
                        <li class="nav-item">
                            <a class="btn btn-outline-warning btn-sm" asp-area="" asp-controller="Product" asp-action="Index">⬅️ Quay lại Web</a>
                        </li>
                        <partial name="_LoginPartial" />
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>