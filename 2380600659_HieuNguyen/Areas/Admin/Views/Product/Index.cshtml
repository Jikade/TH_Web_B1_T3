@model IEnumerable<_2380600659_HieuNguyen.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<h2 class="mb-4">Product Management</h2>

<a asp-action="Add" class="btn btn-primary mb-3">+ Add Product</a>

<table class="table table-bordered table-hover shadow">
    <thead class="table-dark">
        <tr>
            <th width="120">Image</th>
            <th>Name</th>
            <th width="120">Price</th>
            <th>Description</th>
            <th width="150">Category</th>
            <th width="200">Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                    {
                        <img src="@product.ImageUrl" style="width:80px;height:80px;object-fit:cover;border-radius:8px;">
                    }
                </td>

                <td>@product.Name</td>

                <td>
                    <span class="text-success fw-bold">
                        $@product.Price
                    </span>
                </td>

                <td>@product.Description</td>

                <td>@product.Category?.Name</td>

                <td>
                    <a asp-action="Display" asp-route-id="@product.Id"
                           class="btn btn-info btn-sm">
                        View
                    </a>

                    <a asp-action="Update" asp-route-id="@product.Id"
                           class="btn btn-warning btn-sm">
                        Edit
                    </a>

                    <a asp-action="Delete" asp-route-id="@product.Id"
                           class="btn btn-danger btn-sm">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>