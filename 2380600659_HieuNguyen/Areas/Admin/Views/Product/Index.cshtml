@model IEnumerable<_2380600659_HieuNguyen.Models.Product>

@{
    Layout = "_AdminLayout"; // Đảm bảo dùng layout admin ta đã làm
    ViewData["Title"] = "Product Management";
}

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h2 class="fw-bold">📦 Product Management</h2>
        <a asp-action="Add" class="btn btn-primary px-4" style="border-radius: 20px;">
            <i class="me-1 fa fa-plus-circle"></i> Add Product
        </a>
    </div>

    <div class="card shadow-sm mb-4" style="border-radius: 12px; overflow: hidden; border: none;">
        <div class="card-body p-0">
            <table class="table table-bordered table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th width="80" class="text-center">Image</th>
                        <th>Name</th>
                        <th width="120">Price</th>
                        <th>Description</th>
                        <th width="150">Category</th>
                        <th width="150" class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model)
                    {
                        <tr>
                            <td class="text-center align-middle">
                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" style="width:60px;height:60px;object-fit:cover;border-radius:8px;">
                                }
                                else
                                {
                                    <img src="/images/no-image.png" style="width:60px;height:60px;object-fit:cover;border-radius:8px;">
                                }
                            </td>
                            <td class="align-middle fw-bold">@product.Name</td>
                            <td class="align-middle text-success fw-bold fs-5">$@product.Price</td>
                            <td class="align-middle text-muted small">
                                @if (!string.IsNullOrEmpty(product.Description) && product.Description.Length > 60)
                                {
                                    @product.Description.Substring(0, 60)

                                    <span>...</span>
                                }
                                else
                                {
                                    @product.Description
                                }
                            </td>
                            <td class="align-middle">
                                <span class="badge bg-light text-dark border">@product.Category?.Name</span>
                            </td>
                            <td class="align-middle text-center">
                                <a asp-action="Update" asp-route-id="@product.Id" class="btn btn-warning btn-sm me-1">Edit</a>
                                <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-danger btn-sm">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>