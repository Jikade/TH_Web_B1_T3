@model IEnumerable<_2380600659_HieuNguyen.Models.OrderHeader>

@{
    ViewData["Title"] = "Quản lý Đơn hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">📋 Quản lý Đơn hàng</h2>
</div>

<div class="card admin-card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light border-bottom">
                <tr>
                    <th class="ps-4">Mã ĐH</th>
                    <th>Khách hàng</th>
                    <th>Số điện thoại</th>
                    <th>Ngày Đặt</th>
                    <th>Tổng tiền</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-center pe-4">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-primary">#@item.Id</td>
                        <td class="fw-bold">@item.Name</td>
                        <td>@item.PhoneNumber</td>
                        <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-success fw-bold">$@item.OrderTotal</td>
                        <td class="text-center">
                            @if (item.OrderStatus == _2380600659_HieuNguyen.Models.SD.StatusPending)
                            {
                                <span class="badge bg-warning text-dark py-2 px-3">@item.OrderStatus</span>
                            }
                            else if (item.OrderStatus == _2380600659_HieuNguyen.Models.SD.StatusApproved)
                            {
                                <span class="badge bg-primary py-2 px-3">@item.OrderStatus</span>
                            }
                            else if (item.OrderStatus == _2380600659_HieuNguyen.Models.SD.StatusShipped)
                            {
                                <span class="badge bg-success py-2 px-3">@item.OrderStatus</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary py-2 px-3">@item.OrderStatus</span>
                            }
                        </td>
                        <td class="text-center pe-4">
                            <a asp-action="Details" asp-route-orderId="@item.Id" class="btn btn-outline-info btn-sm fw-bold">Chi tiết & Duyệt</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>