@model _2380600659_HieuNguyen.Models.OrderHeader
@using _2380600659_HieuNguyen.Models

@{
    ViewData["Title"] = "Chi tiết Đơn hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Chi tiết Đơn hàng <span class="text-primary">#@Model.Id</span></h2>
    <a asp-action="Index" class="btn btn-secondary px-4 shadow-sm">⬅ Quay lại danh sách</a>
</div>

<div class="row">
    <div class="col-lg-5 mb-4">
        <div class="card admin-card shadow-sm h-100">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="mb-0 fw-bold text-dark">👤 Thông tin Khách hàng</h5>
            </div>
            <div class="card-body">
                <div class="mb-3"><span class="text-muted d-block small">Họ và tên:</span> <span class="fw-bold fs-5">@Model.Name</span></div>
                <div class="mb-3"><span class="text-muted d-block small">Số điện thoại:</span> <span class="fw-bold">@Model.PhoneNumber</span></div>
                <div class="mb-3"><span class="text-muted d-block small">Địa chỉ giao hàng:</span> <span>@Model.Address</span></div>
                <div class="mb-3"><span class="text-muted d-block small">Ngày đặt hàng:</span> <span>@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</span></div>

                <hr class="my-4">

                <h5 class="fw-bold mb-3 text-primary">⚙️ Xử lý đơn hàng</h5>
                <form asp-action="UpdateStatus" method="post">
                    <input type="hidden" name="orderId" value="@Model.Id" />
                    <div class="form-floating mb-3">
                        <select name="status" class="form-select bg-light fw-bold text-primary">
                            <option value="@SD.StatusPending" selected="@(Model.OrderStatus == SD.StatusPending)">⏳ Pending (Chờ duyệt)</option>
                            <option value="@SD.StatusApproved" selected="@(Model.OrderStatus == SD.StatusApproved)">✅ Approved (Đã duyệt)</option>
                            <option value="@SD.StatusShipped" selected="@(Model.OrderStatus == SD.StatusShipped)">🚚 Shipped (Đang giao)</option>
                            <option value="@SD.StatusCancelled" selected="@(Model.OrderStatus == SD.StatusCancelled)">❌ Cancelled (Đã Hủy)</option>
                        </select>
                        <label>Trạng thái hiện tại: @Model.OrderStatus</label>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 fw-bold py-2">Cập Nhật Trạng Thái</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-7 mb-4">
        <div class="card admin-card shadow-sm h-100">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="mb-0 fw-bold text-dark">🛍️ Danh sách Sản phẩm</h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-borderless mb-0">
                    <thead class="bg-light border-bottom">
                        <tr>
                            <th class="ps-4">Sản phẩm</th>
                            <th class="text-center">Đơn giá</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end pe-4">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ViewBag.OrderDetails as IEnumerable<OrderDetail>)
                        {
                            <tr class="border-bottom">
                                <td class="ps-4 py-3 fw-bold">@item.Product.Name</td>
                                <td class="text-center py-3 text-muted">$@item.Price</td>
                                <td class="text-center py-3">x @item.Count</td>
                                <td class="text-end pe-4 py-3 fw-bold">$@(item.Price * item.Count)</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="bg-light">
                            <td colspan="3" class="text-end fw-bold fs-5 py-3">Tổng thanh toán:</td>
                            <td class="text-end pe-4 fw-bold text-success fs-4 py-3">$@Model.OrderTotal</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>