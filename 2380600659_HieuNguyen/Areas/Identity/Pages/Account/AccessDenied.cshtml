@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Từ chối truy cập";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8 text-center">
            <div class="card shadow-lg border-0 rounded-lg overflow-hidden">

                <div class="card-header bg-danger text-white py-4">
                    <div class="display-1 mb-2">🛑</div>
                    <h2 class="fw-bold mb-0">Truy Cập Bị Từ Chối</h2>
                </div>

                <div class="card-body p-4 p-md-5">
                    <h4 class="text-danger fw-bold mb-3">Lỗi 403: Không đủ thẩm quyền</h4>

                    <p class="text-muted fs-5 mb-4">
                        Rất tiếc! Tài khoản của bạn không có đủ quyền (Role) để xem nội dung trang này.
                        Khu vực này chỉ dành riêng cho <strong>Quản trị viên (Admin)</strong>.
                    </p>

                    <hr class="mb-4">

                    <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                        <a asp-area="" asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg px-4 fw-bold" style="border-radius: 30px;">
                            🏠 Về Trang Chủ
                        </a>
                        <a href="javascript:history.back()" class="btn btn-outline-secondary btn-lg px-4 fw-bold" style="border-radius: 30px;">
                            ⬅ Quay Lại Trang Trước
                        </a>
                    </div>
                </div>

                <div class="card-footer bg-light py-3">
                    <span class="small text-muted">Nếu bạn cho rằng đây là một sự nhầm lẫn, vui lòng liên hệ Admin hệ thống.</span>
                </div>
            </div>
        </div>
    </div>
</div>