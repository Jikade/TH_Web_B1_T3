@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng Nhập";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7 col-sm-9">
            <div class="card shadow-lg border-0 rounded-lg">

                <div class="card-header bg-primary text-white text-center py-4" style="border-top-left-radius: 8px; border-top-right-radius: 8px;">
                    <h3 class="font-weight-light my-2 fw-bold">👋 Chào mừng trở lại!</h3>
                    <p class="mb-0 small text-white-50">Vui lòng đăng nhập để tiếp tục</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                        <div class="form-floating mb-4">
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" style="border-radius: 10px;" />
                            <label asp-for="Input.Email" class="form-label text-muted">✉️ Địa chỉ Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" style="border-radius: 10px;" />
                            <label asp-for="Input.Password" class="form-label text-muted">🔒 Mật khẩu</label>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="Input.RememberMe" id="rememberMe" />
                                <label class="form-check-label text-muted" for="rememberMe">
                                    Nhớ mật khẩu
                                </label>
                            </div>
                            <a id="forgot-password" asp-page="./ForgotPassword" class="text-decoration-none small">Quên mật khẩu?</a>
                        </div>

                        <div class="d-grid gap-2 mt-4 mb-0">
                            <button id="login-submit" type="submit" class="btn btn-primary btn-lg fw-bold" style="border-radius: 30px;">
                                Đăng Nhập
                            </button>
                        </div>
                    </form>
                </div>

                <div class="card-footer text-center py-4 bg-light" style="border-bottom-left-radius: 8px; border-bottom-right-radius: 8px;">
                    <div class="small">
                        Chưa có tài khoản?
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="fw-bold text-decoration-none">Đăng ký ngay!</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}